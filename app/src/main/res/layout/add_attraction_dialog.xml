<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/rounded_dialog_background"
    android:padding="@dimen/padding_standard">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/image_card_view"
        android:layout_width="match_parent"
        android:layout_height="@dimen/card_image_height"
        app:cardCornerRadius="@dimen/padding_standard"
        app:cardElevation="@dimen/default_card_elevation"
        app:layout_constraintTop_toTopOf="parent"
        app:strokeWidth="0dp">

        <ImageView
            android:id="@+id/attraction_image_preview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@null"
            android:scaleType="centerCrop" />
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/choose_image_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/text_view_margin_start"
        android:layout_marginTop="@dimen/padding_standard"
        android:fontFamily="@font/be_vietnam_pro_light"
        android:text="@string/choose_image_text"
        android:textColor="@color/md_theme_onPrimaryFixed"
        android:textSize="@dimen/text_medium"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/image_card_view" />

    <LinearLayout
        android:id="@+id/selection_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/padding_small"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/choose_image_label">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/pick_gallery_button"
            style="@style/Widget.Material3.Button.ElevatedButton"
            android:layout_width="@dimen/medium_height"
            android:layout_height="@dimen/medium_height"
            android:layout_marginEnd="@dimen/padding_small"
            app:backgroundTint="@color/md_theme_surface"
            app:cornerRadius="@dimen/default_corner_radius"
            app:icon="@android:drawable/ic_menu_gallery"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconTint="@color/md_theme_tertiary_mediumContrast" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/presets_recycler_view"
            android:layout_width="match_parent"
            android:layout_height="@dimen/high_modifier_size"
            android:orientation="horizontal" />
    </LinearLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/title_input_layout"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/padding_standard"
        app:boxBackgroundColor="@android:color/transparent"
        app:boxCornerRadiusBottomEnd="@dimen/default_corner_radius"
        app:boxCornerRadiusBottomStart="@dimen/default_corner_radius"
        app:boxCornerRadiusTopEnd="@dimen/default_corner_radius"
        app:boxCornerRadiusTopStart="@dimen/default_corner_radius"
        app:boxStrokeWidth="0dp"
        app:layout_constraintTop_toBottomOf="@id/selection_container">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/attraction_title_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/be_vietnam_pro_light"
            android:hint="@string/attraction_title_label" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/description_input_layout"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/default_corner_radius"
        app:boxBackgroundColor="@android:color/transparent"
        app:boxCornerRadiusBottomEnd="@dimen/default_corner_radius"
        app:boxCornerRadiusBottomStart="@dimen/default_corner_radius"
        app:boxCornerRadiusTopEnd="@dimen/default_corner_radius"
        app:boxCornerRadiusTopStart="@dimen/default_corner_radius"
        app:boxStrokeWidth="0dp"
        app:layout_constraintTop_toBottomOf="@id/title_input_layout">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/attraction_description_Input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/be_vietnam_pro_light"
            android:hint="@string/description_title_label"
            android:inputType="textMultiLine"
            android:minLines="@integer/edit_text_min_lines" />
    </com.google.android.material.textfield.TextInputLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
