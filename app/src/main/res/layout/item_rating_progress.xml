<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/padding_small"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <TextView
        android:id="@+id/labelTextView"
        android:layout_width="@dimen/text_view_label_width"
        android:layout_height="wrap_content"
        android:textColor="@color/md_theme_outline"
        android:textSize="@dimen/text_medium" />

    <ProgressBar
        android:id="@+id/ratingProgressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="0dp"
        android:layout_height="@dimen/progress_bar_height"
        android:layout_weight="@integer/view_weight"
        android:max="@integer/max_progress_bar"
        android:progress="0"
        android:progressDrawable="@drawable/bg_rating_progress_rounded" />
</LinearLayout>